<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================ -->
    <!-- BUTTON STYLES (ZButton variants)              -->
    <!-- ============================================ -->

    <style name="Widget.GuardPoint.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.GuardPoint.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.GuardPoint.Button.Ghost" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.GuardPoint.Button.Destructive" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="backgroundTint">@color/error</item>
        <item name="android:textColor">@color/on_error</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.GuardPoint.Button.Small" parent="Widget.GuardPoint.Button">
        <item name="android:minHeight">@dimen/button_height_sm</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.GuardPoint.Button.Large" parent="Widget.GuardPoint.Button">
        <item name="android:minHeight">@dimen/button_height_lg</item>
    </style>

    <!-- ============================================ -->
    <!-- CARD STYLES (ZCard variants)                  -->
    <!-- ============================================ -->

    <style name="Widget.GuardPoint.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
    </style>

    <style name="Widget.GuardPoint.Card.Interactive" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/elevation_md</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.GuardPoint.Card.Compact" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
    </style>

    <!-- ============================================ -->
    <!-- BADGE STYLES (ZBadge variants)                -->
    <!-- ============================================ -->

    <style name="Widget.GuardPoint.Badge" parent="">
        <item name="android:paddingHorizontal">@dimen/badge_padding_horizontal</item>
        <item name="android:paddingVertical">@dimen/badge_padding_vertical</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelSmall</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="Widget.GuardPoint.Badge.Default" parent="Widget.GuardPoint.Badge">
        <item name="android:background">@color/primary_container</item>
        <item name="android:textColor">@color/on_primary_container</item>
    </style>

    <style name="Widget.GuardPoint.Badge.Secondary" parent="Widget.GuardPoint.Badge">
        <item name="android:background">@color/surface_variant</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Widget.GuardPoint.Badge.Destructive" parent="Widget.GuardPoint.Badge">
        <item name="android:background">@color/error_container</item>
        <item name="android:textColor">@color/on_error_container</item>
    </style>

    <style name="Widget.GuardPoint.Badge.Success" parent="Widget.GuardPoint.Badge">
        <item name="android:background">@color/success_container</item>
        <item name="android:textColor">@color/success</item>
    </style>

    <style name="Widget.GuardPoint.Badge.Warning" parent="Widget.GuardPoint.Badge">
        <item name="android:background">@color/warning_container</item>
        <item name="android:textColor">@color/warning</item>
    </style>

    <style name="Widget.GuardPoint.Badge.Pill" parent="Widget.GuardPoint.Badge">
        <item name="android:background">@drawable/bg_badge_pill</item>
    </style>



</resources>
